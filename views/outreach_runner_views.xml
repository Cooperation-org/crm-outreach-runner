<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Dense outreach list: prioritized, key labels + clickable links, no click-in -->
    <record id="view_outreach_runner_tree" model="ir.ui.view">
        <field name="name">crm.lead.outreach.runner.tree</field>
        <field name="model">crm.lead</field>
        <field name="arch" type="xml">
            <tree string="Outreach Runner"
                  default_order="outreach_pinned desc, outreach_seq asc, outreach_score desc"
                  decoration-muted="last_outreach_date != False"
                  decoration-bf="outreach_pinned == True"
                  sample="1">
                <field name="outreach_seq" widget="handle"/>
                <field name="outreach_pinned" column_invisible="1"/>
                <field name="outreach_score_reason" column_invisible="1"/>
                <field name="priority" widget="priority"/>
                <field name="outreach_score" string="Rank" optional="show"/>
                <field name="partner_id" string="Contact"/>
                <field name="function" string="Role" optional="show"/>
                <field name="campaign_id" optional="show"/>
                <field name="partner_category_ids" widget="many2many_tags" string="Tags" optional="show"/>
                <field name="email_from" widget="email" string="Email"/>
                <field name="partner_linkedin" widget="url" string="LinkedIn" optional="show"/>
                <field name="partner_discord" widget="url" string="Discord" optional="show"/>
                <field name="partner_website" widget="url" string="Site" optional="hide"/>
                <field name="phone" widget="phone" optional="hide"/>
                <field name="last_outreach_date" string="Last outreach" optional="show"/>
                <button name="action_mark_contacted" type="object" string="Contacted"
                        icon="fa-check" class="btn-link"
                        help="Log outreach: stamp the time and add a chatter note"/>
            </tree>
        </field>
    </record>

    <!-- Kanban "runner" cards -->
    <record id="view_outreach_runner_kanban" model="ir.ui.view">
        <field name="name">crm.lead.outreach.runner.kanban</field>
        <field name="model">crm.lead</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" default_order="outreach_pinned desc, outreach_seq asc, outreach_score desc" sample="1">
                <field name="priority"/>
                <field name="partner_id"/>
                <field name="function"/>
                <field name="campaign_id"/>
                <field name="email_from"/>
                <field name="partner_linkedin"/>
                <field name="partner_discord"/>
                <field name="partner_website"/>
                <field name="partner_category_ids"/>
                <field name="last_outreach_date"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top mb-1">
                                <strong class="o_kanban_record_title">
                                    <field name="partner_id"/>
                                </strong>
                                <field name="priority" widget="priority"/>
                            </div>
                            <div class="text-muted small">
                                <field name="function"/> · <field name="campaign_id"/>
                            </div>
                            <div class="mt-1">
                                <field name="partner_category_ids" widget="many2many_tags"/>
                            </div>
                            <div class="o_kanban_record_bottom mt-2">
                                <div class="oe_kanban_bottom_left">
                                    <a t-if="record.email_from.raw_value"
                                       t-att-href="'mailto:' + record.email_from.raw_value"
                                       class="btn btn-sm btn-link" title="Email">✉</a>
                                    <a t-if="record.partner_linkedin.raw_value"
                                       t-att-href="record.partner_linkedin.raw_value"
                                       target="_blank" class="btn btn-sm btn-link" title="LinkedIn">in</a>
                                    <a t-if="record.partner_discord.raw_value"
                                       t-att-href="record.partner_discord.raw_value"
                                       target="_blank" class="btn btn-sm btn-link" title="Discord">D</a>
                                    <a t-if="record.partner_website.raw_value"
                                       t-att-href="record.partner_website.raw_value"
                                       target="_blank" class="btn btn-sm btn-link" title="Website">↗</a>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <button name="action_mark_contacted" type="object"
                                            class="btn btn-sm btn-primary">Contacted</button>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Search: filter/group by campaign, priority, not-yet-contacted -->
    <record id="view_outreach_runner_search" model="ir.ui.view">
        <field name="name">crm.lead.outreach.runner.search</field>
        <field name="model">crm.lead</field>
        <field name="arch" type="xml">
            <search string="Outreach">
                <field name="partner_id" string="Contact"/>
                <field name="campaign_id"/>
                <field name="partner_category_ids" string="Tag"/>
                <filter name="not_contacted" string="Not yet contacted"
                        domain="[('last_outreach_date','=',False)]"/>
                <filter name="high_priority" string="High priority"
                        domain="[('priority','&gt;=','2')]"/>
                <separator/>
                <filter name="my" string="My leads" domain="[('user_id','=',uid)]"/>
                <group expand="1" string="Group By">
                    <filter name="by_campaign" string="Campaign" context="{'group_by':'campaign_id'}"/>
                    <filter name="by_priority" string="Priority" context="{'group_by':'priority'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_outreach_runner" model="ir.actions.act_window">
        <field name="name">Outreach Runner</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="domain">[('type','=','opportunity')]</field>
        <field name="search_view_id" ref="view_outreach_runner_search"/>
        <field name="context">{'search_default_not_contacted': 1, 'search_default_by_campaign': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Nothing to reach out to yet</p>
            <p>Opportunities on your campaigns show up here, prioritized for outreach.</p>
        </field>
    </record>

    <!-- Bind our specific tree + kanban to the action -->
    <record id="outreach_runner_act_tree" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="view_outreach_runner_tree"/>
        <field name="act_window_id" ref="action_outreach_runner"/>
    </record>
    <record id="outreach_runner_act_kanban" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">kanban</field>
        <field name="view_id" ref="view_outreach_runner_kanban"/>
        <field name="act_window_id" ref="action_outreach_runner"/>
    </record>

    <!-- Menu under CRM -->
    <menuitem id="menu_outreach_runner"
              name="Outreach Runner"
              parent="crm.crm_menu_root"
              action="action_outreach_runner"
              sequence="20"/>

</odoo>
